# ===========================================
# Application Environment Variables
# ===========================================
# Copy this file to .env and update with your actual values
# The .env file is ignored by git for security

# ===========================================
# Spring Profile
# ===========================================
SPRING_PROFILES_ACTIVE=local

# ===========================================
# Server Configuration
# ===========================================
SERVER_PORT=8080

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/retail_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://:redis_password_123@localhost:6379

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Change this secret in production!
# Must be at least 256 bits (32 characters) for HS256
JWT_SECRET=mySecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongForHS256Algorithm

# ===========================================
# Logging Level (Optional)
# ===========================================
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_APP=DEBUG

